{
  "name": "uzair-waseem-portfolio",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "start": "next start",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "cv:setup": "python scripts/setup_cv.py",
    "cv:generate": "python scripts/run_cv.py scripts/generate_cv.py",
    "cv:tailor": "python scripts/run_cv.py scripts/tailor_cv.py",
    "cv:test": "python scripts/run_cv.py -m unittest discover -s tests -p \"test_cv_*.py\"",
    "cv:validate": "python scripts/run_cv.py scripts/validate_cv.py",
    "cv:qa": "npm run cv:generate && npm run cv:test && npm run cv:validate",
    "check": "npm run lint && npm run typecheck && npm run build",
    "qa": "npm run check && npm run test:e2e",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
